{
  "version": 2,
  "builds": [
    {
      "src": "backend/MyDjangoProyect/MyDjangoProyect/wsgi.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/MyDjangoProyect/MyDjangoProyect/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "backend/MyDjangoProyect/MyDjangoProyect/wsgi.py"
    },
    {
      "src": "/static/admin/(.*)",
      "dest": "backend/MyDjangoProyect/MyDjangoProyect/wsgi.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
